@page "/contato"
@layout MainLayout
@rendermode InteractiveServer
@using Acervo.Web.Components.Layout
@using Acervo.Web.Components.Shared

<PageTitle>Contato — Acervo</PageTitle>

<div class="contact-page">
    <div class="contact-hero">
        <h1 class="contact-hero__title">Fale conosco</h1>
        <p class="contact-hero__subtitle">Estamos aqui para ajudar com dúvidas, sugestões ou suporte.</p>
    </div>

    <div class="contact-body">
        <!-- Formulário -->
        <div class="contact-form-card">
            <h2 class="contact-form-card__title">Enviar mensagem</h2>

            @if (Sent)
            {
                <div class="contact-success">
                    <span>✅</span>
                    <h3>Mensagem enviada!</h3>
                    <p>Responderemos em até 2 dias úteis.</p>
                    <AppButton Variant="outline" OnClickCallback="@(() => Sent = false)">
                        Enviar outra
                    </AppButton>
                </div>
            }
            else
            {
                <div class="contact-form">
                    <AppInput Label="Nome" Placeholder="Seu nome" Width="100%" @bind-Value="ContactName" />
                    <AppInput Label="E-mail" Type="email" Placeholder="seu@email.com" Width="100%" @bind-Value="ContactEmail" />
                    <AppInput Label="Assunto" Placeholder="Como podemos ajudar?" Width="100%" @bind-Value="ContactSubject" />

                    <div class="contact-form__textarea-wrapper">
                        <label class="input-label">Mensagem</label>
                        <textarea class="contact-form__textarea"
                                  placeholder="Descreva sua dúvida ou sugestão…"
                                  rows="5"
                                  @bind="ContactMessage"></textarea>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(FormError))
                    {
                        <div class="contact-form__error">@FormError</div>
                    }

                    <AppButton Color="#c9a84c" TextColor="#0f172a" Size="lg" Width="200px" Height="52px"
                               Loading="@IsSending" LoadingText="Enviando…"
                               OnClickCallback="SendMessage">
                        Enviar mensagem
                    </AppButton>
                </div>
            }
        </div>

        <!-- Informações de contato -->
        <aside class="contact-info">
            <h2 class="contact-info__title">Informações</h2>

            <div class="contact-info__items">
                <div class="contact-info__item">
                    <span class="contact-info__icon">📧</span>
                    <div>
                        <p class="contact-info__label">E-mail</p>
                        <p class="contact-info__value">suporte@acervo.com.br</p>
                    </div>
                </div>
                <div class="contact-info__item">
                    <span class="contact-info__icon">💬</span>
                    <div>
                        <p class="contact-info__label">Chat online</p>
                        <p class="contact-info__value">Seg–Sex, 9h–18h</p>
                    </div>
                </div>
                <div class="contact-info__item">
                    <span class="contact-info__icon">⏱️</span>
                    <div>
                        <p class="contact-info__label">Tempo de resposta</p>
                        <p class="contact-info__value">Até 2 dias úteis</p>
                    </div>
                </div>
            </div>

            <div class="contact-info__faq">
                <h3 class="contact-info__faq-title">Perguntas frequentes</h3>
                @foreach (var faq in Faqs)
                {
                    <div class="faq-item">
                        <p class="faq-item__question">@faq.Q</p>
                        <p class="faq-item__answer">@faq.A</p>
                    </div>
                }
            </div>
        </aside>
    </div>
</div>
