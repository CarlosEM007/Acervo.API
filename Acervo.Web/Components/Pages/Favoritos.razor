@page "/favoritos"
@layout MainLayout
@rendermode InteractiveServer
@using Acervo.Web.Components.Layout
@using Acervo.Web.Components.Shared

<PageTitle>Favoritos — Acervo</PageTitle>

<div class="favs-page">
    <div class="favs-page__header">
        <h1 class="favs-page__title"><i class="fa-solid fa-heart"></i> Favoritos</h1>
        <span class="favs-page__count">@Items.Count @(Items.Count == 1 ? "livro" : "livros")</span>
    </div>

    @if (!Items.Any())
    {
        <div class="favs-empty">
            <span class="favs-empty__icon"><i class="fa-regular fa-heart"></i></span>
            <h2 class="favs-empty__title">Nenhum favorito ainda</h2>
            <p class="favs-empty__text">Salve livros que você quer ler depois.</p>
            <AppButton Color="#c9a84c" TextColor="#0f172a" Size="lg" Width="220px"
                       OnClickCallback="@(() => Navigation.NavigateTo("/catalogo"))">
                Descobrir livros
            </AppButton>
        </div>
    }
    else
    {
        <div class="books-grid">
            @foreach (var item in Items)
            {
                <div class="book-card">
                    <div class="book-card__cover" @onclick="@(() => Navigation.NavigateTo($"/livro/{item.BookId}"))">
                        @if (!string.IsNullOrWhiteSpace(item.CoverImageUrl))
                        {
                            <img src="@item.CoverImageUrl" alt="@item.Title" loading="lazy" />
                        }
                        else
                        {
                            <div class="book-card__cover-placeholder"><i class="fa-solid fa-book-open"></i></div>
                        }
                        <button class="favs-remove-btn" @onclick:stopPropagation="true"
                                @onclick="@(() => RemoveFavorite(item))" title="Remover dos favoritos">
                            <i class="fa-solid fa-heart"></i>
                        </button>
                    </div>
                    <div class="book-card__body">
                        <span class="book-card__category">@item.CategoryName</span>
                        <h3 class="book-card__title">@item.Title</h3>
                        <p class="book-card__author">@item.AuthorName</p>
                        <div class="book-card__price">
                            <span class="book-card__price-current">R$ @item.Price.ToString("N2")</span>
                        </div>
                        <AppButton Color="#16a34a" TextColor="#fff" Size="sm" FullWidth="true"
                                   OnClickCallback="@(() => AddToCart(item))">
                            <i class="fa-solid fa-cart-shopping"></i> Adicionar ao carrinho
                        </AppButton>
                    </div>
                </div>
            }
        </div>
    }
</div>
